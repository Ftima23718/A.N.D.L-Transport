### 3.2 Diagramme de Classes

```mermaid
classDiagram
    class Utilisateur {
        +int id
        +string nom
        +string prenom
        +string email
        +string motDePasse
        +string role
        +string telephone
        +DateTime dateCreation
        +seConnecter()
        +seDeconnecter()
        +reinitialiserMotDePasse()
    }

    class Etudiant {
        +string numeroEtudiant
        +string filiere
        +int anneeEtude
        +string photoURL
        +string carteEtudianteURL
        +getSesInscriptions()
        +getBadge()
    }

    class Administrateur {
        +validerInscription(inscriptionId)
        +rejeterInscription(inscriptionId, motif)
        +exporterRapport(format)
    }

    class ResponsableTransport {
        +gererLigne(ligne)
        +affecterBus(bus, ligne)
        +affecterChauffeur(chauffeur, trajet)
    }

    class Chauffeur {
        +string numeroPermis
        +getPlanning()
        +getListePassagers(trajetId)
    }

    class Inscription {
        +int id
        +DateTime dateInscription
        +string statut
        +string typeAbonnement
        +DateTime dateDebut
        +DateTime dateFin
        +string motifRejet
        +soumettre()
        +annuler()
        +renouveler()
    }

    class Ligne {
        +int id
        +string nom
        +string description
        +string pointDepart
        +string pointArrivee
        +boolean estActive
        +getArrets()
        +getTrajetsDuJour()
    }

    class Arret {
        +int id
        +string nom
        +string adresse
        +int ordre
        +string coordonnees
    }

    class Bus {
        +int id
        +string immatriculation
        +string marque
        +int capacite
        +string statut
    }

    class Trajet {
        +int id
        +DateTime heureDepart
        +DateTime heureArrivee
        +string joursSemaine
        +int placesDisponibles
        +reserverPlace()
        +libererPlace()
    }

    class Paiement {
        +int id
        +double montant
        +DateTime datePaiement
        +string modePaiement
        +string statut
        +string referenceTransaction
        +genererRecu()
    }

    class Badge {
        +int id
        +string codeQR
        +DateTime dateExpiration
        +boolean estValide
        +genererPDF()
        +verifier()
    }

    class Notification {
        +int id
        +string type
        +string message
        +DateTime dateEnvoi
        +boolean estLue
        +envoyer()
    }

    class Tarif {
        +int id
        +string typeAbonnement
        +double montant
        +string description
        +calculerMontant()
    }

    Utilisateur <|-- Etudiant
    Utilisateur <|-- Administrateur
    Utilisateur <|-- ResponsableTransport
    Utilisateur <|-- Chauffeur

    Etudiant "1" --> "0..*" Inscription : soumet
    Inscription "1" --> "1" Ligne : concerne
    Inscription "1" --> "1" Arret : arrêt choisi
    Inscription "1" --> "0..1" Paiement : génère
    Inscription "1" --> "0..1" Badge : produit
    Inscription "1" --> "1" Tarif : applique

    Ligne "1" --> "1..*" Arret : comprend
    Ligne "1" --> "0..*" Trajet : planifie
    Trajet "1" --> "1" Bus : utilise
    Trajet "1" --> "0..1" Chauffeur : conduit par

    Utilisateur "1" --> "0..*" Notification : reçoit
```

